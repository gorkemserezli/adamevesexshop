{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Adam & Eve Sex Shop design tokens — DTCG flat tree. Light values are primary; dark mode is supplied as $extensions.com.adamandeve.dark.",

  "color": {
    "wine": {
      "50":  { "$type": "color", "$value": "#FBF3F2", "$extensions": { "com.adamandeve.dark": "#2A100E" } },
      "100": { "$type": "color", "$value": "#F2E0DC", "$extensions": { "com.adamandeve.dark": "#3A1814" } },
      "200": { "$type": "color", "$value": "#E2BBB2", "$extensions": { "com.adamandeve.dark": "#4A1E1A" } },
      "300": { "$type": "color", "$value": "#C58A7E", "$extensions": { "com.adamandeve.dark": "#6B2E26" } },
      "400": { "$type": "color", "$value": "#A05B4E", "$extensions": { "com.adamandeve.dark": "#A55B4D" } },
      "500": { "$type": "color", "$value": "#6B2E26", "$extensions": { "com.adamandeve.dark": "#BC685A" }, "$description": "Primary brand wine. Aged-leather red-brown, low saturation." },
      "600": { "$type": "color", "$value": "#5A2620", "$extensions": { "com.adamandeve.dark": "#C77264" } },
      "700": { "$type": "color", "$value": "#4A1E1A", "$extensions": { "com.adamandeve.dark": "#D08474" } },
      "900": { "$type": "color", "$value": "#2A100E", "$extensions": { "com.adamandeve.dark": "#E5A89B" } }
    },
    "bronze": {
      "50":  { "$type": "color", "$value": "#F8F1E5", "$extensions": { "com.adamandeve.dark": "#2C2316" } },
      "100": { "$type": "color", "$value": "#ECDCBA", "$extensions": { "com.adamandeve.dark": "#3C2E15" } },
      "200": { "$type": "color", "$value": "#DCC18B", "$extensions": { "com.adamandeve.dark": "#564220" } },
      "300": { "$type": "color", "$value": "#C4A165", "$extensions": { "com.adamandeve.dark": "#71562F" } },
      "400": { "$type": "color", "$value": "#A88546", "$extensions": { "com.adamandeve.dark": "#B59A6E" }, "$description": "Hairline rule color (used at 30% opacity)." },
      "500": { "$type": "color", "$value": "#8C6D40", "$extensions": { "com.adamandeve.dark": "#C9A98A" }, "$description": "Decorative ink only — fails AA for body text on cream." },
      "600": { "$type": "color", "$value": "#71562F", "$extensions": { "com.adamandeve.dark": "#D8B886" }, "$description": "Curator-note italic ink — passes AA on cream." },
      "700": { "$type": "color", "$value": "#564220", "$extensions": { "com.adamandeve.dark": "#E8CBA0" } },
      "800": { "$type": "color", "$value": "#3C2E15", "$extensions": { "com.adamandeve.dark": "#F4DFBA" } }
    },
    "neutral": {
      "canvas":  { "$type": "color", "$value": "#F9F4EC", "$extensions": { "com.adamandeve.dark": "#1A140F" }, "$description": "Page background; warm cream / cocoa." },
      "surface": { "$type": "color", "$value": "#F2EBDD", "$extensions": { "com.adamandeve.dark": "#261D14" }, "$description": "Raised cards, modals, sheets." },
      "sunken":  { "$type": "color", "$value": "#EFE4D0", "$extensions": { "com.adamandeve.dark": "#120D09" } },
      "ink":     { "$type": "color", "$value": "#2A1E16", "$extensions": { "com.adamandeve.dark": "#F0E6D5" }, "$description": "Primary text, warm dark brown-black." },
      "ink-2":   { "$type": "color", "$value": "#4A3829", "$extensions": { "com.adamandeve.dark": "#C9B89F" } },
      "ink-3":   { "$type": "color", "$value": "#6B5642", "$extensions": { "com.adamandeve.dark": "#8F7E66" } }
    },
    "hairline": {
      "default": { "$type": "color", "$value": "rgba(168, 133, 70, 0.30)", "$extensions": { "com.adamandeve.dark": "rgba(216, 184, 134, 0.20)" } },
      "soft":    { "$type": "color", "$value": "rgba(168, 133, 70, 0.15)", "$extensions": { "com.adamandeve.dark": "rgba(216, 184, 134, 0.10)" } }
    },
    "semantic": {
      "success": {
        "bg":   { "$type": "color", "$value": "#E5E8D9", "$extensions": { "com.adamandeve.dark": "#2A3320" } },
        "ink":  { "$type": "color", "$value": "#3F4933", "$extensions": { "com.adamandeve.dark": "#B7C29C" } },
        "mark": { "$type": "color", "$value": "#5C6B4A", "$extensions": { "com.adamandeve.dark": "#8FA070" } }
      },
      "warning": {
        "bg":   { "$type": "color", "$value": "#F2E2BD", "$extensions": { "com.adamandeve.dark": "#3D2D14" } },
        "ink":  { "$type": "color", "$value": "#6B4A1E", "$extensions": { "com.adamandeve.dark": "#E5C589" } },
        "mark": { "$type": "color", "$value": "#A87830", "$extensions": { "com.adamandeve.dark": "#D9A656" } }
      },
      "danger": {
        "bg":   { "$type": "color", "$value": "#ECCFC4", "$extensions": { "com.adamandeve.dark": "#3D1F16" } },
        "ink":  { "$type": "color", "$value": "#7A3525", "$extensions": { "com.adamandeve.dark": "#E8AE9B" } },
        "mark": { "$type": "color", "$value": "#B4533A", "$extensions": { "com.adamandeve.dark": "#D67560" } }
      },
      "info": {
        "bg":   { "$type": "color", "$value": "#ECDCBA", "$extensions": { "com.adamandeve.dark": "#2C2316" } },
        "ink":  { "$type": "color", "$value": "#564220", "$extensions": { "com.adamandeve.dark": "#D8B886" } },
        "mark": { "$type": "color", "$value": "#71562F", "$extensions": { "com.adamandeve.dark": "#D8B886" } }
      }
    },
    "alias": {
      "bg":             { "$type": "color", "$value": "{color.neutral.canvas}" },
      "bg-elevated":    { "$type": "color", "$value": "{color.neutral.surface}" },
      "bg-sunken":      { "$type": "color", "$value": "{color.neutral.sunken}" },
      "text":           { "$type": "color", "$value": "{color.neutral.ink}" },
      "text-muted":     { "$type": "color", "$value": "{color.neutral.ink-2}" },
      "text-subtle":    { "$type": "color", "$value": "{color.neutral.ink-3}" },
      "text-on-wine":   { "$type": "color", "$value": "#F9F4EC", "$extensions": { "com.adamandeve.dark": "#1A140F" } },
      "text-on-bronze": { "$type": "color", "$value": "#F9F4EC", "$extensions": { "com.adamandeve.dark": "#1A140F" } },
      "accent":         { "$type": "color", "$value": "{color.wine.500}" },
      "accent-press":   { "$type": "color", "$value": "{color.wine.600}" },
      "accent-soft":    { "$type": "color", "$value": "{color.wine.100}" },
      "decor":          { "$type": "color", "$value": "{color.bronze.400}" },
      "decor-ink":      { "$type": "color", "$value": "{color.bronze.600}" },
      "overlay":        { "$type": "color", "$value": "rgba(42, 30, 22, 0.50)", "$extensions": { "com.adamandeve.dark": "rgba(0, 0, 0, 0.65)" } }
    }
  },

  "font": {
    "family": {
      "serif": { "$type": "fontFamily", "$value": ["Cormorant Garamond", "AE Serif Italic", "Georgia", "serif"] },
      "sans":  { "$type": "fontFamily", "$value": ["Inter", "system-ui", "-apple-system", "Segoe UI", "sans-serif"] }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium":  { "$type": "fontWeight", "$value": 500 },
      "bold":    { "$type": "fontWeight", "$value": 600 }
    },
    "size": {
      "display-lg": { "$type": "dimension", "$value": "40px" },
      "display":    { "$type": "dimension", "$value": "32px" },
      "h1":         { "$type": "dimension", "$value": "28px" },
      "h2":         { "$type": "dimension", "$value": "22px" },
      "h3":         { "$type": "dimension", "$value": "18px" },
      "h4":         { "$type": "dimension", "$value": "16px" },
      "body-lg":    { "$type": "dimension", "$value": "17px" },
      "body":       { "$type": "dimension", "$value": "15px" },
      "body-sm":    { "$type": "dimension", "$value": "13px" },
      "caption":    { "$type": "dimension", "$value": "12px" },
      "overline":   { "$type": "dimension", "$value": "11px" },
      "ui-label":   { "$type": "dimension", "$value": "13px" },
      "nav-label":  { "$type": "dimension", "$value": "11px" },
      "price":      { "$type": "dimension", "$value": "22px" },
      "curator":    { "$type": "dimension", "$value": "14px" }
    },
    "lineHeight": {
      "display-lg": { "$type": "number", "$value": 1.08 },
      "display":    { "$type": "number", "$value": 1.15 },
      "h1":         { "$type": "number", "$value": 1.20 },
      "h2":         { "$type": "number", "$value": 1.25 },
      "h3":         { "$type": "number", "$value": 1.30 },
      "h4":         { "$type": "number", "$value": 1.40 },
      "body-lg":    { "$type": "number", "$value": 1.55 },
      "body":       { "$type": "number", "$value": 1.55 },
      "body-sm":    { "$type": "number", "$value": 1.50 },
      "caption":    { "$type": "number", "$value": 1.40 },
      "overline":   { "$type": "number", "$value": 1.30 },
      "ui-label":   { "$type": "number", "$value": 1.20 },
      "price":      { "$type": "number", "$value": 1.20 },
      "curator":    { "$type": "number", "$value": 1.50 }
    },
    "letterSpacing": {
      "display":  { "$type": "string", "$value": "-0.01em" },
      "h1":       { "$type": "string", "$value": "-0.005em" },
      "tight":    { "$type": "string", "$value": "-0.005em" },
      "normal":   { "$type": "string", "$value": "0" },
      "ui":       { "$type": "string", "$value": "0.02em" },
      "caption":  { "$type": "string", "$value": "0.01em" },
      "overline": { "$type": "string", "$value": "0.20em" },
      "nav":      { "$type": "string", "$value": "0.01em" }
    }
  },

  "spacing": {
    "1":  { "$type": "dimension", "$value": "4px" },
    "2":  { "$type": "dimension", "$value": "8px" },
    "3":  { "$type": "dimension", "$value": "12px" },
    "4":  { "$type": "dimension", "$value": "16px" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px" },
    "7":  { "$type": "dimension", "$value": "32px" },
    "8":  { "$type": "dimension", "$value": "40px" },
    "10": { "$type": "dimension", "$value": "48px" },
    "12": { "$type": "dimension", "$value": "64px" },
    "16": { "$type": "dimension", "$value": "80px" },
    "20": { "$type": "dimension", "$value": "96px" },
    "24": { "$type": "dimension", "$value": "128px" },
    "gutter-mobile":      { "$type": "dimension", "$value": "24px" },
    "gutter-mobile-hero": { "$type": "dimension", "$value": "32px" },
    "gutter-tablet":      { "$type": "dimension", "$value": "32px" },
    "gutter-desktop":     { "$type": "dimension", "$value": "64px" }
  },

  "radius": {
    "sm":   { "$type": "dimension", "$value": "6px" },
    "md":   { "$type": "dimension", "$value": "10px" },
    "lg":   { "$type": "dimension", "$value": "14px" },
    "xl":   { "$type": "dimension", "$value": "20px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },

  "shadow": {
    "none":  { "$type": "shadow", "$value": [] },
    "sheet": { "$type": "shadow", "$value": [
      { "color": "rgba(42, 30, 22, 0.12)", "offsetX": "0", "offsetY": "12px", "blur": "40px", "spread": "0" }
    ], "$extensions": { "com.adamandeve.dark": [
      { "color": "rgba(0, 0, 0, 0.50)", "offsetX": "0", "offsetY": "12px", "blur": "40px", "spread": "0" }
    ] } }
  },

  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "180ms" },
      "base": { "$type": "duration", "$value": "280ms" },
      "slow": { "$type": "duration", "$value": "400ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] },
      "emphasis": { "$type": "cubicBezier", "$value": [0.16, 1, 0.30, 1] }
    }
  },

  "layout": {
    "viewport": {
      "min":        { "$type": "dimension", "$value": "320px" },
      "mobile-max": { "$type": "dimension", "$value": "430px" },
      "tablet":     { "$type": "dimension", "$value": "768px" },
      "desktop":    { "$type": "dimension", "$value": "1024px" },
      "wide":       { "$type": "dimension", "$value": "1280px" }
    },
    "content": {
      "max-text":    { "$type": "dimension", "$value": "720px" },
      "max-catalog": { "$type": "dimension", "$value": "960px" },
      "max-pdp":     { "$type": "dimension", "$value": "1120px" }
    }
  },

  "z": {
    "base":     { "$type": "number", "$value": 0 },
    "sticky":   { "$type": "number", "$value": 30 },
    "dropdown": { "$type": "number", "$value": 40 },
    "sheet":    { "$type": "number", "$value": 50 },
    "toast":    { "$type": "number", "$value": 60 },
    "modal":    { "$type": "number", "$value": 70 }
  }
}
