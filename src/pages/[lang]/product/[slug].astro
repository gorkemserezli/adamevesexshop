---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Breadcrumb from "~/components/ui/Breadcrumb.astro";
import ProductHero from "~/components/product/ProductHero.astro";
import StockBadge from "~/components/product/StockBadge.astro";
import CuratorNote from "~/components/product/CuratorNote.astro";
import VariantSelector from "~/components/product/VariantSelector.astro";
import SpecList from "~/components/product/SpecList.astro";
import Accordion from "~/components/product/Accordion.astro";
import ActionBar from "~/components/product/ActionBar.astro";
import type { Locale } from "~/i18n/ui";
import { LOCALES, ui } from "~/i18n/ui";
import { getCollection, type CollectionEntry } from "astro:content";
import { categoryHref } from "~/lib/routes";
import { formatPriceDisplay } from "~/i18n/format";

export async function getStaticPaths() {
  const products = await getCollection("products");
  const paths = [];
  for (const lang of LOCALES) {
    for (const p of products) {
      paths.push({ params: { lang, slug: p.data.id }, props: { product: p.data } });
    }
  }
  return paths;
}

type Props = { product: import("~/content/config").Product };

const { lang } = Astro.params as { lang: Locale };
const { product } = Astro.props as Props;
const t = ui[lang];

const categoryEntries = await getCollection("categories");
const category = categoryEntries.find(
  (c: CollectionEntry<"categories">) => c.data.id === product.category_id,
)?.data;

const breadcrumbCrumbs = [
  ...(category ? [{ label: category.name[lang], href: categoryHref(lang, category.id) }] : []),
  { label: product.name[lang] },
];

// Stock state is now build-time-only via product.sold_out (populated by
// fetch.php from Entegra). No runtime fetch — the badge renders its final
// state at SSR and never changes during the page lifetime.
const stockVariant: "sold_out" | "in_stock" = product.sold_out ? "sold_out" : "in_stock";

// v1.2 simplification: render-time filter on the specs array. Hotel team
// wants only Brand visible; Size + Weight + any future rows are dropped
// from the rendered output. Match against the canonical Turkish label
// "Marka" — fetch.php always writes that string for the Brand row, so it
// works as a stable identifier independent of which locale is rendering.
// JSON keeps the full specs array for forward-compat / debugging; this is
// purely a UI patch that can be reverted by deleting the filter line.
const visibleSpecs = product.specs.filter((s) => s.label.tr === "Marka");

const title = `Adam & Eve · ${product.name[lang]}`;
---

<BaseLayout title={title} lang={lang}>
  <Breadcrumb lang={lang} crumbs={breadcrumbCrumbs} />

  <div class="mt-3">
    <ProductHero images={product.images} productName={product.name[lang]} lang={lang} />
  </div>

  <section class="px-ae-6 pt-ae-7">
    <div class="text-overline text-ink-3 uppercase">{product.overline[lang]}</div>
    <h1
      class="font-serif text-h1 text-ink mt-2 tracking-tight"
      style="hyphens: manual;"
    >
      {product.name[lang]}
    </h1>
    <p
      class="ae-pdp-sku text-caption mt-2 tnum"
      style="color: var(--ae-ink-3); letter-spacing: 0.06em; font-variant: small-caps;"
    >
      SKU: <span style="font-variant: normal; letter-spacing: 0.04em;">{product.sku}</span>
    </p>
    <div class="font-serif text-price text-ink mt-3 tnum">
      {formatPriceDisplay(product.price[lang].value, product.price[lang].currency, lang)}
    </div>

    <div class="mt-4">
      <StockBadge lang={lang} variant={stockVariant} />
    </div>

    {product.curator_note && (
      <div class="mt-4">
        <CuratorNote text={product.curator_note[lang]} clamp={2} />
      </div>
    )}
  </section>

  {
    product.variants.length > 0 && (
      <>
        <div class="px-ae-6 mt-7">
          <div class="border-t border-hairline" />
        </div>
        <section class="px-ae-6 pt-ae-6">
          <VariantSelector axes={product.variants} lang={lang} />
        </section>
      </>
    )
  }

  <section class="px-ae-6 pt-ae-7">
    <Accordion id="ae-pdp-description" title={t.pdp.descriptionLabel}>
      <p class="text-body-lg text-ink-2 pt-ae-3 pb-ae-2" style="hyphens: auto;">
        {product.description[lang]}
      </p>
    </Accordion>
  </section>

  {
    visibleSpecs.length > 0 && (
      <section class="px-ae-6 pt-ae-6">
        <SpecList specs={visibleSpecs} lang={lang} />
      </section>
    )
  }

  <div class="px-ae-6 mt-2 mb-6"><div class="border-t border-hairline"></div></div>

  <ActionBar product={product} lang={lang} />

</BaseLayout>
