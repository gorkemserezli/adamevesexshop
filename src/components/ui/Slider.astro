---
import type { Locale } from "~/i18n/ui";
import { ui } from "~/i18n/ui";

interface Props {
  id: string;
  lang: Locale;
  min: number;
  max: number;
  step: number;
  initialMin: number;
  initialMax: number;
}

const { id, lang, min, max, step, initialMin, initialMax } = Astro.props;
const t = ui[lang];
---

<div
  id={id}
  class="ae-slider"
  role="group"
  aria-label={t.filter.priceRange}
  data-min={String(min)}
  data-max={String(max)}
  data-step={String(step)}
  data-locale={lang}
  data-current-min={String(initialMin)}
  data-current-max={String(initialMax)}
>
  <div class="ae-slider-track-area" data-slider-track-area>
    <div class="ae-slider-track" aria-hidden="true"></div>
    <div class="ae-slider-range" aria-hidden="true"></div>
    <div class="ae-slider-thumb ae-slider-thumb-min" aria-hidden="true"></div>
    <div class="ae-slider-thumb ae-slider-thumb-max" aria-hidden="true"></div>
    <input
      type="range"
      class="ae-slider-input ae-slider-input-min"
      min={String(min)}
      max={String(max)}
      step={String(step)}
      value={String(initialMin)}
      aria-label={t.filter.priceMinAria}
    />
    <input
      type="range"
      class="ae-slider-input ae-slider-input-max"
      min={String(min)}
      max={String(max)}
      step={String(step)}
      value={String(initialMax)}
      aria-label={t.filter.priceMaxAria}
    />
  </div>
</div>

<style is:global>
  .ae-slider {
    position: relative;
    padding: 22px 12px; /* leave 22px above/below the 4px track for 44x44 touch zone */
  }
  .ae-slider-track-area {
    position: relative;
    height: 4px;
  }
  .ae-slider-track {
    position: absolute;
    inset: 0;
    background-color: var(--ae-bronze-400);
    border-radius: 9999px;
  }
  .ae-slider-range {
    position: absolute;
    top: 0;
    bottom: 0;
    background-color: var(--ae-wine-500);
    border-radius: 9999px;
  }
  .ae-slider-thumb {
    position: absolute;
    top: 50%;
    left: 0;
    width: 20px;
    height: 20px;
    margin-left: -10px;
    border-radius: 50%;
    background-color: var(--ae-wine-500);
    border: 2px solid var(--ae-canvas);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
    transform: translateY(-50%);
    pointer-events: none;
    transition: transform var(--ae-dur-fast) var(--ae-ease-standard);
  }
  /* Native inputs sit on top of the visual thumbs at 44x44 hit size, transparent. */
  .ae-slider-input {
    position: absolute;
    top: 50%;
    width: 44px;
    height: 44px;
    margin: -22px 0 0 -22px;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    /* Visually hide while staying interactive and screen-readable. */
    opacity: 0;
    /* Native track styling reset so the box never blocks touches outside the 44x44. */
    pointer-events: auto;
    /* Bug 1 (v1.1): suppress native click-to-position scrubbing — we drive the
       value from custom pointer events so a tap doesn't collapse to min/max. */
    touch-action: none;
    /* The input itself is positioned to overlap a single thumb. JS keeps left in sync. */
  }
  .ae-slider-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 44px;
    height: 44px;
    background: transparent;
  }
  .ae-slider-input::-moz-range-thumb {
    width: 44px;
    height: 44px;
    background: transparent;
    border: 0;
  }
  .ae-slider-input:focus-visible + .ae-slider-thumb,
  .ae-slider-input:focus-visible {
    outline: none;
  }
  /* Focus ring shows on the visual thumb when its native input is focused. */
  .ae-slider-input.ae-slider-input-min:focus-visible ~ .ae-slider-thumb-min,
  .ae-slider-input.ae-slider-input-max:focus-visible ~ .ae-slider-thumb-max {
    outline: 2px solid var(--ae-wine-500);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .ae-slider-thumb { transition: none !important; }
  }
</style>

<script>
  import { formatPriceForScreenReader } from "~/i18n/format";
  import type { Locale } from "~/i18n/ui";
  import { ui } from "~/i18n/ui";
  import { writeThumbValue, dragDeltaToValue } from "~/lib/slider";

  function init(slider: HTMLElement): void {
    const min = Number(slider.dataset.min);
    const max = Number(slider.dataset.max);
    const step = Number(slider.dataset.step);
    const lang = (slider.dataset.locale ?? "en") as Locale;
    const t = ui[lang];

    const trackArea = slider.querySelector<HTMLElement>("[data-slider-track-area]");
    const range = slider.querySelector<HTMLElement>(".ae-slider-range");
    const thumbMin = slider.querySelector<HTMLElement>(".ae-slider-thumb-min");
    const thumbMax = slider.querySelector<HTMLElement>(".ae-slider-thumb-max");
    const inputMin = slider.querySelector<HTMLInputElement>(".ae-slider-input-min");
    const inputMax = slider.querySelector<HTMLInputElement>(".ae-slider-input-max");

    if (!trackArea || !range || !thumbMin || !thumbMax || !inputMin || !inputMax) return;

    const bounds = { min, max };

    function pctOf(v: number): number {
      if (max === min) return 0;
      return ((v - min) / (max - min)) * 100;
    }

    function applyWrite(which: "min" | "max", raw: number): void {
      const next = writeThumbValue(which, raw, {
        current: { min: Number(inputMin!.value), max: Number(inputMax!.value) },
        bounds,
        step,
      });
      inputMin!.value = String(next.min);
      inputMax!.value = String(next.max);
      paint();
      slider.dispatchEvent(new CustomEvent("ae:slider-change", {
        bubbles: true,
        detail: { min: next.min, max: next.max },
      }));
    }

    function paint(): void {
      const minV = Number(inputMin!.value);
      const maxV = Number(inputMax!.value);
      const minPct = pctOf(minV);
      const maxPct = pctOf(maxV);
      thumbMin!.style.left = `${minPct}%`;
      thumbMax!.style.left = `${maxPct}%`;
      range!.style.left = `${minPct}%`;
      range!.style.width = `${maxPct - minPct}%`;
      inputMin!.style.left = `${minPct}%`;
      inputMax!.style.left = `${maxPct}%`;
      inputMin!.setAttribute("aria-valuetext", formatPriceForScreenReader(minV, lang));
      inputMax!.setAttribute("aria-valuetext", formatPriceForScreenReader(maxV, lang));
      slider.setAttribute(
        "aria-label",
        t.filter.priceRangeWithBounds(
          formatPriceForScreenReader(minV, lang),
          formatPriceForScreenReader(maxV, lang),
        ),
      );
      slider.dataset.currentMin = String(minV);
      slider.dataset.currentMax = String(maxV);
    }

    /**
     * Bug 1 (v1.1): we suppress the native range input's click-to-position
     * scrubbing entirely — a touch tap on the max thumb used to fire `input`
     * with value≈min and collapse the slider. Custom pointer drag below means
     * a tap without movement leaves the value untouched, and a real drag is
     * computed from delta-X on the track instead of native scrubbing.
     */
    function bindPointerDrag(input: HTMLInputElement, which: "min" | "max"): void {
      let dragging = false;
      let pointerId = -1;
      let startX = 0;
      let startValue = 0;
      let trackWidth = 0;

      input.addEventListener("pointerdown", (e: PointerEvent) => {
        e.preventDefault();
        e.stopPropagation();
        try { input.setPointerCapture(e.pointerId); } catch { /* old browser */ }
        pointerId = e.pointerId;
        dragging = true;
        startX = e.clientX;
        startValue = Number(input.value);
        trackWidth = trackArea!.getBoundingClientRect().width;
        input.focus({ preventScroll: true });
      });

      input.addEventListener("pointermove", (e: PointerEvent) => {
        if (!dragging || e.pointerId !== pointerId) return;
        const delta = dragDeltaToValue(startX, e.clientX, trackWidth, bounds);
        applyWrite(which, startValue + delta);
      });

      const end = (e: PointerEvent): void => {
        if (!dragging || e.pointerId !== pointerId) return;
        dragging = false;
        pointerId = -1;
        try { input.releasePointerCapture(e.pointerId); } catch { /* noop */ }
      };
      input.addEventListener("pointerup", end);
      input.addEventListener("pointercancel", end);

      // Keyboard / screen-reader path. The native input fires `input` for
      // ArrowLeft/Right, Home, End, PageUp/Down, and VO/TalkBack swipes — but
      // it ALSO fires from native scrubbing on touch, which we mute here.
      input.addEventListener("input", () => {
        if (dragging) return;
        applyWrite(which, Number(input.value));
      });
    }

    bindPointerDrag(inputMin!, "min");
    bindPointerDrag(inputMax!, "max");

    // Pointer on track itself (outside the 44x44 thumb hit zones) — choose the
    // closer thumb and jump to that position. Unchanged from v1.0; kept since
    // the bug was specific to thumb taps, not track taps.
    trackArea!.addEventListener("pointerdown", (e) => {
      if ((e.target as HTMLElement).classList.contains("ae-slider-input")) return;
      const rect = trackArea!.getBoundingClientRect();
      const px = e.clientX - rect.left;
      const pct = Math.max(0, Math.min(1, px / rect.width));
      const v = min + pct * (max - min);
      const minV = Number(inputMin!.value);
      const maxV = Number(inputMax!.value);
      const which = Math.abs(v - minV) <= Math.abs(v - maxV) ? "min" : "max";
      applyWrite(which, v);
      (which === "min" ? inputMin! : inputMax!).focus({ preventScroll: true });
    });

    paint();
  }

  document.querySelectorAll<HTMLElement>(".ae-slider").forEach(init);
</script>
