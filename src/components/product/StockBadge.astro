---
/**
 * Stock state on the PDP. Now build-time-only — `sold_out` lives on the
 * product JSON (populated by fetch.php from Entegra). No runtime fetch,
 * no hydrator, no skeleton state. The badge renders its final variant at
 * SSR and stays put for the lifetime of the page.
 *
 * `last_n` and `available_at_boutique` variants are retained for future
 * surfaces that may want richer stock signalling (e.g., a build-time
 * "low stock" derive from inventory counts), but the PDP only emits
 * `in_stock` or `sold_out` today.
 */
import type { Locale } from "~/i18n/ui";
import { ui } from "~/i18n/ui";

type Variant = "in_stock" | "last_n" | "sold_out" | "available_at_boutique";

interface Props {
  lang: Locale;
  variant: Variant;
  count?: number;
}

const { lang, variant, count } = Astro.props;
const t = ui[lang];

const labelMap: Record<Variant, string> = {
  in_stock: t.stock.inStock,
  last_n: t.stock.lastN(count ?? 0),
  sold_out: t.stock.soldOut,
  available_at_boutique: t.stock.atBoutique,
};

const variantStyles: Record<Variant, string> = {
  in_stock:
    "background-color: var(--ae-success-bg); color: var(--ae-success-ink);",
  last_n:
    "background-color: var(--ae-warning-bg); color: var(--ae-warning-ink);",
  sold_out:
    "background-color: var(--ae-danger-bg); color: var(--ae-danger-ink);",
  available_at_boutique:
    "background-color: var(--ae-info-bg); color: var(--ae-info-ink);",
};

const markStyles: Record<Variant, string> = {
  in_stock: "background-color: var(--ae-success-mark);",
  last_n: "background-color: var(--ae-warning-mark);",
  sold_out: "background-color: transparent;",
  available_at_boutique: "background-color: var(--ae-info-mark);",
};

const showMark = variant !== "sold_out";
---

<span
  class="ae-stock-badge inline-flex items-center gap-2 h-6 px-[10px] rounded-pill text-caption font-medium"
  style={variantStyles[variant]}
  data-variant={variant}
>
  {showMark && (
    <span class="ae-stock-mark block w-1.5 h-1.5 rounded-pill" style={markStyles[variant]} aria-hidden="true" />
  )}
  <span class="ae-stock-label">{labelMap[variant]}</span>
</span>
