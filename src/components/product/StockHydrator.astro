---
import type { Product } from "~/content/config";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const variantsByOption: Record<string, string> = {};
for (const axis of product.variants) {
  for (const opt of axis.options) {
    variantsByOption[opt.id] = axis.id;
  }
}

const productData = {
  sku: product.sku,
  axes: product.variants.map((a) => ({
    id: a.id,
    options: a.options.map((o) => ({ id: o.id, available: o.available })),
  })),
};
---

<script
  is:inline
  type="application/json"
  id={`stock-product-${product.sku}`}
  set:html={JSON.stringify(productData)}
></script>

<script>
  import { fetchStock, buildVariantKey, type StockResponse, type StockStatus } from "~/lib/stock";

  interface ProductData {
    sku: string;
    axes: Array<{ id: string; options: Array<{ id: string; available: boolean }> }>;
  }

  function readProductData(): ProductData | null {
    const node = document.querySelector<HTMLScriptElement>('script[id^="stock-product-"]');
    if (!node || !node.textContent) return null;
    try {
      return JSON.parse(node.textContent) as ProductData;
    } catch {
      return null;
    }
  }

  function paintBadge(badge: HTMLElement, status: StockStatus, count: number | null): void {
    const labelEl = badge.querySelector<HTMLElement>(".ae-stock-label");
    const markEl = badge.querySelector<HTMLElement>(".ae-stock-mark");
    if (!labelEl) return;

    badge.setAttribute("data-variant", status);
    badge.classList.remove("ae-stock-skeleton");

    const STYLE: Record<StockStatus, { bg: string; ink: string; mark: string; showMark: boolean }> = {
      in_stock: { bg: "var(--ae-success-bg)", ink: "var(--ae-success-ink)", mark: "var(--ae-success-mark)", showMark: true },
      last_n: { bg: "var(--ae-warning-bg)", ink: "var(--ae-warning-ink)", mark: "var(--ae-warning-mark)", showMark: true },
      sold_out: { bg: "var(--ae-danger-bg)", ink: "var(--ae-danger-ink)", mark: "transparent", showMark: false },
      available_at_boutique: { bg: "var(--ae-info-bg)", ink: "var(--ae-info-ink)", mark: "var(--ae-info-mark)", showMark: true },
    };
    const s = STYLE[status];
    badge.style.backgroundColor = s.bg;
    badge.style.color = s.ink;
    if (markEl) {
      markEl.style.backgroundColor = s.mark;
      markEl.style.display = s.showMark ? "" : "none";
    }

    if (status === "last_n" && count !== null) {
      const tmpl = badge.dataset.labelLastNTemplate ?? "Last {n} left";
      labelEl.textContent = tmpl.replace("{n}", String(count));
    } else if (status === "in_stock") {
      labelEl.textContent = badge.dataset.labelInStock ?? "In Stock";
    } else if (status === "sold_out") {
      labelEl.textContent = badge.dataset.labelSoldOut ?? "Sold Out";
    } else {
      labelEl.textContent = badge.dataset.labelAtBoutique ?? "Available at boutique";
    }
  }

  function applyVariantAvailability(response: StockResponse, productData: ProductData): void {
    const chips = document.querySelectorAll<HTMLButtonElement>(".ae-chip[data-option-id]");
    if (productData.axes.length === 0) return;

    const optionToAxis = new Map<string, string>();
    for (const axis of productData.axes) {
      for (const opt of axis.options) optionToAxis.set(opt.id, axis.id);
    }

    const liveByOption = new Map<string, boolean>();
    for (const optId of optionToAxis.keys()) liveByOption.set(optId, false);

    for (const [variantKey, vstock] of Object.entries(response.variants)) {
      const optIds = variantKey.split("__");
      const isAvailable = vstock.status !== "sold_out";
      for (const oid of optIds) {
        if (isAvailable) liveByOption.set(oid, true);
      }
    }

    chips.forEach((chip) => {
      const optId = chip.dataset.optionId;
      if (!optId) return;
      const contentAvailable = chip.dataset.available !== "false";
      const liveAvailable = liveByOption.get(optId) === true;
      const finalAvailable = contentAvailable && liveAvailable;
      const before = chip.dataset.available;
      chip.dataset.available = finalAvailable ? "true" : "false";
      if (chip.dataset.available !== before) {
        chip.dispatchEvent(new CustomEvent("ae:availability-change", { bubbles: false }));
      }
    });
  }

  function statusForCurrentSelection(response: StockResponse, productData: ProductData): { status: StockStatus; count: number | null } {
    if (productData.axes.length === 0) {
      const v = response.variants["_"];
      if (v) return { status: v.status, count: v.in_stock };
      return { status: "available_at_boutique", count: null };
    }
    const selection: Record<string, string> = {};
    for (const axis of productData.axes) {
      const checkedChip = document.querySelector<HTMLButtonElement>(
        `.ae-chip[data-axis-id="${axis.id}"][aria-checked="true"]`,
      );
      const optId = checkedChip?.dataset.optionId ?? axis.options[0]?.id;
      if (optId) selection[axis.id] = optId;
    }
    try {
      const key = buildVariantKey(
        productData.axes.map((a) => ({
          id: a.id,
          label: { tr: "", en: "", de: "", ru: "" },
          options: a.options.map((o) => ({
            id: o.id,
            label: { tr: "", en: "", de: "", ru: "" },
            available: o.available,
          })),
        })),
        selection,
      );
      const v = response.variants[key];
      if (v) return { status: v.status, count: v.in_stock };
    } catch {
      /* fall through */
    }
    return { status: "available_at_boutique", count: null };
  }

  async function hydrate(): Promise<void> {
    const productData = readProductData();
    if (!productData) return;
    const badge = document.querySelector<HTMLElement>("[data-stock-target]");
    if (!badge) return;

    const result = await fetchStock([productData.sku]);
    const response = result[productData.sku];
    if (!response) return;

    applyVariantAvailability(response, productData);
    const { status, count } = statusForCurrentSelection(response, productData);
    paintBadge(badge, status, count);

    document.querySelectorAll<HTMLButtonElement>(".ae-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        if (chip.getAttribute("data-available") === "false") return;
        const updated = statusForCurrentSelection(response, productData);
        paintBadge(badge, updated.status, updated.count);
      });
    });
  }

  hydrate();
</script>
