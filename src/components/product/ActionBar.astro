---
import type { Locale } from "~/i18n/ui";
import type { Product } from "~/content/config";
import { ui } from "~/i18n/ui";
import { buildWhatsAppHref } from "~/i18n/whatsapp";

interface Props {
  product: Product;
  lang: Locale;
}

const { product, lang } = Astro.props;
const t = ui[lang];
const waHref = buildWhatsAppHref(product, lang);
---

<section class="ae-action-bar px-ae-6 pb-ae-6" data-sku={product.sku}>
  <button
    type="button"
    class="ae-fav-btn block w-full h-14 rounded-md font-medium text-ui-label"
    style="background-color: var(--ae-wine-500); color: var(--ae-canvas);"
    data-sku={product.sku}
    data-label-add={t.cta.addToFavorites}
    data-label-remove={t.cta.removeFromFavorites}
    data-label-favorited={t.pdp.favorited}
    data-toast-added={t.toast.addedToFavorites}
    data-toast-removed={t.toast.removedFromFavorites}
    aria-pressed="false"
  >
    <span class="ae-fav-content flex items-center justify-center gap-2">
      <svg
        class="ae-fav-heart"
        width="18"
        height="18"
        viewBox="0 0 18 18"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path
          d="M9 15.5 3.2 9.8a3.4 3.4 0 0 1 4.8-4.8L9 6l1-1a3.4 3.4 0 0 1 4.8 4.8z"
          stroke-linejoin="round"
        ></path>
      </svg>
      <span class="ae-fav-label">{t.cta.addToFavorites}</span>
    </span>
  </button>

  <a
    href={waHref}
    target="_blank"
    rel="noopener noreferrer"
    class="ae-ask-btn flex w-full h-12 mt-3 rounded-md border font-medium text-ui-label no-underline items-center justify-center gap-2"
    style="background-color: transparent; border-color: var(--ae-hairline); color: var(--ae-wine-500);"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <!-- Official WhatsApp brand mark from simple-icons (CC0). Single path,
           24×24 viewBox, chat-bubble outline + receiver glyph fully contained. -->
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"
      ></path>
    </svg>
    <span>{t.cta.askAtBoutique}</span>
  </a>
</section>

<script>
  import { isFavorite, toggleFavorite, subscribeToFavorites } from "~/lib/favorites";
  import { showToast } from "~/lib/toast";

  document.querySelectorAll<HTMLButtonElement>(".ae-fav-btn").forEach((btn) => {
    const sku = btn.dataset.sku!;
    const labelEl = btn.querySelector<HTMLElement>(".ae-fav-label")!;
    const heartEl = btn.querySelector<SVGElement>(".ae-fav-heart")!;
    const labelAdd = btn.dataset.labelAdd!;
    const labelFavorited = btn.dataset.labelFavorited!;
    const toastAdded = btn.dataset.toastAdded ?? "";
    const toastRemoved = btn.dataset.toastRemoved ?? "";

    function paint(active: boolean): void {
      btn.setAttribute("aria-pressed", active ? "true" : "false");
      labelEl.textContent = active ? labelFavorited : labelAdd;
      heartEl.setAttribute("fill", active ? "currentColor" : "none");
    }
    paint(isFavorite(sku));

    btn.addEventListener("click", () => {
      const next = toggleFavorite(sku);
      paint(next);
      showToast(next ? toastAdded : toastRemoved);
    });

    subscribeToFavorites((favs) => paint(favs.includes(sku)));
  });
</script>
