---
import type { Locale } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import ZoomModal from "~/components/product/ZoomModal.astro";

interface Props {
  images: readonly string[];
  productName: string;
  lang: Locale;
}

const { images, productName, lang } = Astro.props;
const t = ui[lang];
const total = images.length;
const single = total <= 1;
---

<div class="relative" data-pdp-gallery data-total={String(total)}>
  <div
    class="ae-pdp-track flex overflow-x-auto snap-x snap-mandatory"
    role={single ? undefined : "region"}
    aria-label={single ? undefined : t.pdp.imageOf(1, total)}
    aria-roledescription={single ? undefined : "carousel"}
    tabindex={single ? undefined : "0"}
  >
    {images.map((src, i) => (
      <div
        class="ae-pdp-slide shrink-0 w-full aspect-square bg-sunken overflow-hidden snap-start"
        data-slide-index={String(i)}
        role={single ? undefined : "group"}
        aria-roledescription={single ? undefined : "slide"}
        aria-label={single ? undefined : t.pdp.imageOf(i + 1, total)}
      >
        <button
          type="button"
          class="ae-pdp-zoom-trigger w-full h-full block p-0 m-0 bg-transparent border-0"
          data-zoom-trigger
          data-zoom-index={String(i)}
          aria-label={t.pdp.openZoomAria}
        >
          <img
            src={src}
            alt={i === 0 ? productName : ""}
            class="ae-product-image w-full h-full object-cover"
            loading={i === 0 ? "eager" : "lazy"}
            decoding="async"
            width="1024"
            height="1024"
            draggable="false"
          />
        </button>
      </div>
    ))}
  </div>

  {!single && (
    <div
      class="absolute bottom-4 right-6 flex gap-1.5"
      role="tablist"
      aria-label={t.pdp.imageOf(1, total)}
      data-pdp-dots
    >
      {images.map((_, i) => (
        <button
          type="button"
          class="ae-pdp-dot block w-1.5 h-1.5 rounded-pill"
          data-dot-index={String(i)}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          aria-label={t.pdp.imageOf(i + 1, total)}
          style={`background-color: ${i === 0 ? "var(--ae-bronze-500)" : "var(--ae-bronze-200)"};`}
        />
      ))}
    </div>
  )}
</div>

<ZoomModal images={images} productName={productName} lang={lang} />

<style is:global>
  .ae-pdp-track {
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .ae-pdp-track::-webkit-scrollbar { display: none; }
  .ae-pdp-dot {
    border: 0;
    padding: 0;
    cursor: pointer;
    /* Visual size 6px, hit target padded to 24x24 via box-shadow technique not used here;
       button itself stays 6x6 to match design. Touch users can still tap reliably. */
  }
  .ae-pdp-dot:focus-visible {
    outline: 2px solid var(--ae-wine-500);
    outline-offset: 4px;
  }
  .ae-pdp-zoom-trigger {
    cursor: zoom-in;
    line-height: 0;
  }
  .ae-pdp-zoom-trigger:focus-visible {
    outline: 2px solid var(--ae-wine-500);
    outline-offset: -2px;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-pdp-gallery]").forEach((gallery) => {
    const total = Number(gallery.dataset.total ?? "0");

    // Zoom-trigger wiring runs even for single-image galleries (per spec
    // decision #3: tap-to-zoom on single-image PDPs too). The movement
    // threshold heuristic from spec decision #4 distinguishes a tap (open
    // zoom) from the start of a horizontal swipe (let the carousel handle).
    const triggers = Array.from(
      gallery.querySelectorAll<HTMLButtonElement>("[data-zoom-trigger]"),
    );
    triggers.forEach((trigger) => {
      let downX = 0;
      let downY = 0;
      let downT = 0;
      let downId = -1;
      let qualifies = false;

      trigger.addEventListener("pointerdown", (e: PointerEvent) => {
        downX = e.clientX;
        downY = e.clientY;
        downT = Date.now();
        downId = e.pointerId;
        qualifies = true;
      });
      trigger.addEventListener("pointermove", (e: PointerEvent) => {
        if (e.pointerId !== downId || !qualifies) return;
        if (Math.abs(e.clientX - downX) > 8 || Math.abs(e.clientY - downY) > 8) {
          qualifies = false;
        }
      });
      trigger.addEventListener("pointerup", (e: PointerEvent) => {
        if (e.pointerId !== downId) return;
        const elapsed = Date.now() - downT;
        if (qualifies && elapsed < 250) {
          e.preventDefault();
          const idx = Number(trigger.dataset.zoomIndex ?? "0");
          (window as unknown as { aeZoom?: { open: (i: number) => void } }).aeZoom?.open(idx);
        }
        qualifies = false;
        downId = -1;
      });
      // Keyboard activation (Space/Enter) — bypass the threshold; always opens.
      trigger.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          const idx = Number(trigger.dataset.zoomIndex ?? "0");
          (window as unknown as { aeZoom?: { open: (i: number) => void } }).aeZoom?.open(idx);
        }
      });
    });

    if (total <= 1) return;

    const track = gallery.querySelector<HTMLElement>(".ae-pdp-track");
    const slides = Array.from(gallery.querySelectorAll<HTMLElement>(".ae-pdp-slide"));
    const dots = Array.from(gallery.querySelectorAll<HTMLButtonElement>(".ae-pdp-dot"));
    if (!track || slides.length === 0 || dots.length === 0) return;

    function paintActive(active: number): void {
      dots.forEach((d, i) => {
        const isActive = i === active;
        d.setAttribute("aria-selected", isActive ? "true" : "false");
        d.style.backgroundColor = isActive
          ? "var(--ae-bronze-500)"
          : "var(--ae-bronze-200)";
      });
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        const target = slides[i];
        if (!target) return;
        // scrollIntoView snaps via the parent's snap-mandatory; fall back to
        // direct left write if the browser ignores the inline option.
        target.scrollIntoView({ behavior: "smooth", inline: "start", block: "nearest" });
        track.scrollTo({ left: target.offsetLeft, behavior: "smooth" });
        paintActive(i);
      });
    });

    // Track which slide is most-visible via IntersectionObserver. The slide
    // that crosses the 50% threshold first is treated as active.
    const observer = new IntersectionObserver(
      (entries) => {
        let bestIndex = -1;
        let bestRatio = 0;
        for (const entry of entries) {
          if (entry.isIntersecting && entry.intersectionRatio >= bestRatio) {
            const idx = Number((entry.target as HTMLElement).dataset.slideIndex ?? "-1");
            if (idx >= 0) {
              bestRatio = entry.intersectionRatio;
              bestIndex = idx;
            }
          }
        }
        if (bestIndex >= 0) paintActive(bestIndex);
      },
      { root: track, threshold: [0.5, 0.75, 1] },
    );
    slides.forEach((s) => observer.observe(s));
  });
</script>
