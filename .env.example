# Hotel concierge WhatsApp number, E.164 format. Used to compose
# build-time wa.me deep-links per locale per product (rule #8).
HOTEL_WHATSAPP_NUMBER=+905000000000

# Hotel display name (page <title>, footer copy).
HOTEL_NAME=Adam & Eve Hotels Belek

# Boutique location string per locale (rendered in homepage footer
# and About sheet). Per-locale to avoid runtime translation.
HOTEL_BOUTIQUE_LOCATION_TR=Lobi katı, Adam & Eve Hotel Belek
HOTEL_BOUTIQUE_LOCATION_EN=Lobby level, Adam & Eve Hotel Belek
HOTEL_BOUTIQUE_LOCATION_DE=Lobby-Ebene, Adam & Eve Hotel Belek
HOTEL_BOUTIQUE_LOCATION_RU=Уровень лобби, Adam & Eve Hotel Belek

# Boutique opening hours, 24h HH:MM.
HOTEL_HOURS_OPEN=09:00
HOTEL_HOURS_CLOSE=23:00

# Stock API endpoint. Read at module-eval time of src/lib/env.ts —
# missing env = build failure (intentional safety rail per spec
# §5.5). The PDP stock client (src/lib/stock.ts) GETs this URL,
# 60s in-memory cache, 3s timeout. Failure falls back to "Available
# at Boutique" — never surface error UI to the guest.
#
# Prefixed with PUBLIC_ so Vite inlines it into the client bundle.
# For local dev, point at the static fixture:
#   PUBLIC_STOCK_API_URL=/api/mock-stock.json
# Production sets this to the real boutique stock endpoint.
PUBLIC_STOCK_API_URL=/api/mock-stock.json

# Public origin used for canonical URLs and the wa.me composer.
SITE_URL=https://catalog.placeholder.invalid

# Destination for the age gate "Leave" affordance.
# Required at build. Build fails loudly if unset OR if value matches
# /^https:\/\/example\.com/i (placeholder rejection rail; prevents the
# dev fallback from silently shipping to prod).
# REPLACE WITH ACTUAL HOTEL MARKETING URL — this placeholder is for local dev only.
HOTEL_MARKETING_URL=https://placeholder.local/hotel-marketing
